# apps/invite/.env -- gitignored; mode 600 on the server (./deploy enforces it).

# Who may be invited (comma/space separated).
ALLOWED_EMAIL_DOMAINS=example.org

# Groups offered on the invite form (must match users_database.yml groups /
# the OIDC role mapping of your apps).
GROUPS=planka-users,planka-owners,planka-admins

# openssl rand -hex 32
CSRF_SECRET=

# Postgres DSN for the planka-postgres provisioner (see provisioners.yaml;
# the role is created with the narrow grants in the README).
PLANKA_DSN=postgresql://invite:CHANGE_ME@planka-db/planka

# Welcome email over SMTP submission (STARTTLS), e.g. AWS SES.
EMAIL_BACKEND=smtp
EMAIL_HOST=email-smtp.ap-southeast-2.amazonaws.com
EMAIL_PORT=587
EMAIL_USERNAME=
EMAIL_PASSWORD=
EMAIL_FROM=accounts@example.org
EMAIL_SUBJECT_PREFIX=[Example Org]

# Optional: push a notification for every user mutation.
#NTFY_URL=https://ntfy.example.org/user-portal
